{:paths ["src"]
 ;; Built on langgraph-clj (graph agent loop) which brings langchain-clj
 ;; (ChatModel / tools / Datomic-API store). Both are zero-third-party-dep .cljc.
 :deps {io.github.kotoba-lang/langgraph
        {:local/root "../langgraph"}}
 :aliases
 {:test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}
  ;; local checkouts for workspace development (orgs/kotoba-lang/*)
  :dev {:override-deps {io.github.kotoba-lang/langgraph
                        {:local/root "../langgraph"}
                        io.github.kotoba-lang/langchain
                        {:local/root "../langchain"}}}
  ;; Real browser via Playwright — used by examples/yoro_visual_test.clj live mode
  ;; Model: Murakumo LiteLLM 127.0.0.1:4000 (ADR-2605215000 Murakumo-only invariant)
  ;; Fallback (Murakumo down): Ollama 127.0.0.1:11434 local inference
  :playwright {:extra-paths ["examples" "test-playwright"]
               :extra-deps {com.microsoft.playwright/playwright {:mvn/version "1.44.0"}
                            clj-http/clj-http                  {:mvn/version "3.13.0"}
                            cheshire/cheshire                  {:mvn/version "5.13.0"}}}
  ;; Production CapSolver JVM transport. Portable adapter/tests stay zero-dep.
  :capsolver {:extra-paths ["examples"]
              :extra-deps {cheshire/cheshire {:mvn/version "5.13.0"}}}
  ;; clj-kondo as a Clojars lib (no Homebrew/system install needed).
  :lint {:replace-deps {clj-kondo/clj-kondo {:mvn/version "2024.11.14"}}
         :main-opts ["-m" "clj-kondo.main" "--lint" "src" "test"
                     "--fail-level" "error"]}}}
